// Local laptop test profile — tiny inputs, no real images required.
// Used by every `main-*.nf` runner with `-profile test`.

params {
    test_name = 'world'        // hello-py / hello-r greet target
    outdir    = './results'
}

// For the test profile, run with no container so newcomers can try the
// pattern without Docker. Real runs use `-profile docker` (or lifebit).
process {
    executor = 'local'
    container = null
}
