// Lifebit profile — run on the Lifebit CloudOS platform.
//
// Annie note: when deploying a specific main-<name>.nf to Lifebit, you may
// need to copy or symlink it to main.nf at deploy time if the platform
// requires that exact filename. TBD — Annie to confirm.

docker {
    enabled = true
}

process {
    executor = 'awsbatch'    // Lifebit dispatches to AWS Batch under the hood
    queue    = params.queue ?: 'lifebit-default-queue'
}

aws {
    region = params.aws_region ?: 'us-east-1'
}
