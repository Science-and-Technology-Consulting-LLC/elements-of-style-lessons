// Shared Nextflow config. Workflow- and platform-specific overrides
// live under configs/. Pattern mirrors sc-nsforest-qc-nf.

nextflow.enable.dsl = 2

manifest {
    name        = 'elements-of-style-lessons'
    description = 'Companion to "Elements of Style in Creating Workflows for Biomedical Research in the Era of Agentic AI"'
    version     = '0.1.0'
    nextflowVersion = '>=23.04.0'
}

profiles {
    test     { includeConfig 'configs/test.config'     }
    docker   { includeConfig 'configs/docker.config'   }
    lifebit  { includeConfig 'configs/lifebit.config'  }
}

// Sensible defaults
process {
    errorStrategy = 'finish'
    cache         = 'lenient'
}
